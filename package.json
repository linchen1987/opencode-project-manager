{
  "name": "opencode-project",
  "version": "1.0.0",
  "description": "CLI tool for managing OpenCode projects",
  "type": "module",
  "bin": {
    "opencode-project": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/linchen1987/opencode-project-manager.git"
  },
  "bugs": {
    "url": "https://github.com/linchen1987/opencode-project-manager/issues"
  },
  "homepage": "https://github.com/linchen1987/opencode-project-manager#readme",
  "scripts": {
    "build": "tsup index.ts --format esm --dts --clean",
    "dev": "tsx index.ts",
    "test": "vitest run",
    "prepublishOnly": "pnpm run build",
    "release": "npm publish",
    "version:patch": "npm version patch",
    "version:minor": "npm version minor",
    "version:major": "npm version major",
    "pack:check": "pnpm pack --dry-run"
  },
  "keywords": [
    "opencode",
    "cli",
    "project-manager"
  ],
  "author": "Link1987 <link.lin.1987@gmail.com>",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.15.21",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "chalk": "^5.4.1",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.43.1",
    "xdg-basedir": "^5.1.0",
    "zod": "^3.24.4"
  },
  "packageManager": "pnpm@10.30.3+sha512.c961d1e0a2d8e354ecaa5166b822516668b7f44cb5bd95122d590dd81922f606f5473b6d23ec4a5be05e7fcd18e8488d47d978bbe981872f1145d06e9a740017"
}
